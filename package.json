{
  "name": "draft",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predeploy": "npm run build",
    "build:gh": "npm run build",
    "deploy": "gh-pages -d dist",
    "build": "vite build --base=/draft/",
    "dev": "vite",
    "lint": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:a11y": "vitest run src/app/components/accessibility.a11y.test.tsx",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:env": "node scripts/check-env-contract.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "verify:postdeploy": "node scripts/verify-post-deploy.mjs",
    "redeploy:release": "powershell -ExecutionPolicy Bypass -File scripts/redeploy-release.ps1",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint"
    ]
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@sentry/react": "^10.44.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "logrocket": "^12.1.0",
    "lucide-react": "0.487.0",
    "next-themes": "0.4.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "2.1.7",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.13",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
